{
  "entities": {
    "user": {
      "title": "User Profile",
      "description": "User account demographic and preference settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "customer"] },
        "savedAddresses": { "type": "array" },
        "wishlist": { "type": "array" }
      },
      "required": ["uid", "email", "displayName", "role"]
    },
    "order": {
      "title": "Order",
      "description": "Customizable cake and checkout details representing an order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerInfo": { "type": "object" },
        "shippingAddress": { "type": "object" },
        "items": { "type": "array" },
        "subtotal": { "type": "number" },
        "deliveryCharge": { "type": "number" },
        "discount": { "type": "number" },
        "total": { "type": "number" },
        "deliveryDate": { "type": "string" },
        "deliveryTimeSlot": { "type": "string" },
        "deliveryType": { "type": "string", "enum": ["standard", "fast"] },
        "deliveryInstructions": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Preparing", "Out for Delivery", "Delivered", "Cancelled"] },
        "createdAt": { "type": "string" },
        "paymentMethod": { "type": "string" }
      },
      "required": ["id", "customerInfo", "shippingAddress", "items", "total", "status", "createdAt"]
    },
    "query": {
      "title": "Admin Query",
      "description": "A communication message sent by client to Admin Deepika",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Responded"] },
        "createdAt": { "type": "string" },
        "responseText": { "type": "string" },
        "respondedAt": { "type": "string" }
      },
      "required": ["id", "name", "email", "subject", "message", "status", "createdAt"]
    },
    "review": {
      "title": "Review",
      "description": "Rating and feedback submitted by customers for bento cakes",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "avatar": { "type": "string" },
        "cakeName": { "type": "string" },
        "approved": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "name", "rating", "comment", "avatar", "cakeName", "approved", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "user",
      "description": "Isolated user profile matching the user account credentials"
    },
    "/orders/{orderId}": {
      "schema": "order",
      "description": "Orders submitted by user and managed by Admin Deepika"
    },
    "/queries/{queryId}": {
      "schema": "query",
      "description": "Customer enquiries directed to Admin Deepika"
    },
    "/reviews/{reviewId}": {
      "schema": "review",
      "description": "Customer comments and rating cards vetted by Deepika"
    }
  }
}
